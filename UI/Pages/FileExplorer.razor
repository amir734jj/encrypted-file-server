@page "/files/{DataSourceId:guid}"
@page "/files/{DataSourceId:guid}/{**Path}"
@inject ApiService Api
@inject AuthService Auth
@inject NavigationManager Nav
@inject IHxMessengerService Messenger
@inject IHxMessageBoxService MessageBox
@inject IJSRuntime JS
@using Shared.Models

@if (!Auth.IsAuthenticated)
{
    Nav.NavigateTo("/login");
    return;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/datasources">Data Sources</a></li>
        @{
            var segments = GetPathSegments();
        }
        @if (segments.Count == 0)
        {
            <li class="breadcrumb-item active">Files</li>
        }
        else
        {
            <li class="breadcrumb-item"><a href="/files/@DataSourceId">Root</a></li>
            @for (var i = 0; i < segments.Count; i++)
            {
                var breadcrumbPath = string.Join("/", segments.Take(i + 1));
                if (i == segments.Count - 1)
                {
                    <li class="breadcrumb-item active">@segments[i]</li>
                }
                else
                {
                    <li class="breadcrumb-item"><a href="/files/@DataSourceId/@breadcrumbPath">@segments[i]</a></li>
                }
            }
        }
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3><i class="bi bi-folder2-open me-2"></i>@(segments.Count > 0 ? segments.Last() : "Files")</h3>
    <div class="d-flex gap-2">
        @if (_listing is not null && (_listing.Folders.Count > 0 || _listing.Files.Count > 0))
        {
            <HxButton Color="ThemeColor.Danger" Size="ButtonSize.Small" Outline="true" OnClick="DeleteAll">
                <i class="bi bi-trash me-1"></i> Delete All
            </HxButton>
        }
        <InputFile @key="_uploadInputKey" OnChange="HandleFileUpload" class="d-none" id="fileUpload" multiple />
        <label for="fileUpload" class="btn btn-primary btn-sm">
            <i class="bi bi-upload me-1"></i> Upload Files
        </label>
    </div>
</div>

@if (_uploading)
{
    <div class="alert alert-info">
        <div class="d-flex align-items-center mb-2">
            <div class="spinner-border spinner-border-sm me-2"></div>
            <span>Uploading file @_uploadCurrent of @_uploadTotal: <strong>@_uploadFileName</strong></span>
        </div>
        <div class="progress" style="height: 6px;">
            <div class="progress-bar progress-bar-striped progress-bar-animated"
                 style="width: @(_uploadTotal > 0 ? (int)(100.0 * _uploadCurrent / _uploadTotal) : 0)%"></div>
        </div>
    </div>
}

@if (_listing is null)
{
    <div class="d-flex align-items-center">
        <div class="spinner-border spinner-border-sm me-2"></div>
        Loading...
    </div>
}
else if (_listing.Folders.Count == 0 && _listing.Files.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>Empty folder. Upload files or create a subfolder.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle file-table">
            <thead>
                <tr>
                    <th class="col-name">Name</th>
                    <th class="col-size">Size</th>
                    <th class="col-type">Type</th>
                    <th class="col-modified">Modified</th>
                    <th class="col-actions text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (segments.Count > 0)
                {
                    var parentPath = segments.Count > 1
                        ? string.Join("/", segments.Take(segments.Count - 1))
                        : "";
                    <tr class="cursor-pointer" @onclick="() => NavigateTo(parentPath)">
                        <td class="col-name"><i class="bi bi-arrow-up me-1 text-muted"></i> ..</td>
                        <td class="col-size"></td><td class="col-type"></td><td class="col-modified"></td><td class="col-actions"></td>
                    </tr>
                }
                @foreach (var folder in _listing.Folders)
                {
                    var folderPath = string.IsNullOrEmpty(Path) ? folder.Name : $"{Path}/{folder.Name}";
                    <tr class="cursor-pointer" @onclick="() => NavigateTo(folderPath)">
                        <td class="col-name" title="@folder.Name">
                            <i class="bi bi-folder-fill text-warning me-1"></i>
                            @folder.Name
                        </td>
                        <td class="col-size">@FormatBytes(folder.TotalSize)</td>
                        <td class="col-type"><span class="badge bg-secondary">folder</span></td>
                        <td class="col-modified"></td>
                        <td class="col-actions text-end">
                            <HxButton Color="ThemeColor.Warning" Size="ButtonSize.Small" Outline="true"
                                      OnClick="() => ShowMoveFolder(folder)" OnClickStopPropagation="true"
                                      title="Move">
                                <i class="bi bi-arrows-move"></i>
                            </HxButton>
                            <HxButton Color="ThemeColor.Danger" Size="ButtonSize.Small" Outline="true"
                                      OnClick="() => DeleteFolder(folder)" OnClickStopPropagation="true">
                                <i class="bi bi-trash"></i>
                            </HxButton>
                        </td>
                    </tr>
                }
                @foreach (var file in _listing.Files)
                {
                    <tr>
                        <td class="col-name" title="@file.FileName">
                            <i class="bi bi-file-earmark me-1 text-muted"></i>
                            @file.FileName
                        </td>
                        <td class="col-size">@FormatBytes(file.FileSize)</td>
                        <td class="col-type"><span class="badge bg-secondary">@(file.ContentType ?? "unknown")</span></td>
                        <td class="col-modified">@(file.Modified?.LocalDateTime.ToString("MMM dd, yyyy HH:mm") ?? "—")</td>
                        <td class="col-actions text-end">
                            <HxButton Color="ThemeColor.Success" Size="ButtonSize.Small" Outline="true" OnClick="() => DownloadFile(file)">
                                <i class="bi bi-download"></i>
                            </HxButton>
                            <HxButton Color="ThemeColor.Danger" Size="ButtonSize.Small" Outline="true" OnClick="() => DeleteFile(file)">
                                <i class="bi bi-trash"></i>
                            </HxButton>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <small class="text-muted">
        @_listing.Folders.Count folder(s), @_listing.Files.Count file(s)
    </small>
}

@if (_movingFolder is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Move "@_movingFolder.Name"</h5>
                    <button type="button" class="btn-close" @onclick="CancelMove"></button>
                </div>
                <div class="modal-body">
                    <p>Select destination folder:</p>
                    <div class="list-group">
                        @if (GetPathSegments().Count > 0)
                        {
                            <button class="list-group-item list-group-item-action @(_moveDestination == ".." ? "active" : "")"
                                    @onclick='() => _moveDestination = ".."'>                                <i class="bi bi-arrow-up me-1"></i> .. (parent)
                            </button>
                        }
                        @if (_listing is not null)
                        {
                            @foreach (var folder in _listing.Folders.Where(f => f.Name != _movingFolder!.Name))
                            {
                                var name = folder.Name;
                                <button class="list-group-item list-group-item-action @(_moveDestination == name ? "active" : "")"
                                        @onclick="() => _moveDestination = name">
                                    <i class="bi bi-folder-fill text-warning me-1"></i> @name
                                </button>
                            }
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <HxButton Color="ThemeColor.Secondary" OnClick="CancelMove">Cancel</HxButton>
                    <HxButton Color="ThemeColor.Primary" OnClick="ExecuteMove" Enabled="@(!string.IsNullOrEmpty(_moveDestination))">
                        <i class="bi bi-arrows-move me-1"></i> Move
                    </HxButton>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid DataSourceId { get; set; }
    [Parameter] public string? Path { get; set; }

    private DirectoryListingDto? _listing;
    private bool _uploading;
    private int _uploadCurrent;
    private int _uploadTotal;
    private string _uploadFileName = string.Empty;
    private int _uploadInputKey;
    private FolderEntryDto? _movingFolder;
    private string? _moveDestination;


    protected override async Task OnParametersSetAsync()
    {
        if (!Auth.IsAuthenticated)
        {
            return;
        }

        _listing = null; // Show loading spinner while fetching
        StateHasChanged();
        await LoadAsync();
    }

    private List<string> GetPathSegments() =>
        string.IsNullOrEmpty(Path)
            ? []
            : Path.Split('/', StringSplitOptions.RemoveEmptyEntries).ToList();

    private async Task LoadAsync()
    {
        try
        {
            _listing = await Api.GetFilesAsync(DataSourceId, Path ?? "");
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Failed to load: {ex.Message}");
            _listing = new DirectoryListingDto("", [], []);
        }
    }

    private void NavigateTo(string folderPath)
    {
        var url = string.IsNullOrEmpty(folderPath)
            ? $"/files/{DataSourceId}"
            : $"/files/{DataSourceId}/{folderPath}";
        Nav.NavigateTo(url);
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles(20);
        _uploading = true;
        _uploadCurrent = 0;
        _uploadTotal = files.Count;
        StateHasChanged();

        foreach (var file in files)
        {
            _uploadCurrent++;
            _uploadFileName = file.Name;
            StateHasChanged();
            try
            {
                await using var stream = file.OpenReadStream(maxAllowedSize: 500_000_000);
                await Api.UploadFileAsync(DataSourceId, Path ?? "", stream, file.Name,
                    file.ContentType ?? "application/octet-stream");
            }
            catch (Exception ex)
            {
                Messenger.AddError($"Failed to upload {file.Name}: {ex.Message}");
            }
        }

        _uploading = false;
        _uploadInputKey++;
        await LoadAsync();
        StateHasChanged();
        Messenger.AddInformation($"Uploaded {_uploadTotal} file(s).");
    }

    private async Task DownloadFile(FileEntryDto file)
    {
        try
        {
            var baseUrl = Nav.BaseUri.TrimEnd('/');
            var fullPath = string.IsNullOrEmpty(Path) ? file.FileName : $"{Path}/{file.FileName}";
            var url = $"{baseUrl}/api/files/download?dataSourceId={DataSourceId}&path={Uri.EscapeDataString(fullPath)}";
            await JS.InvokeVoidAsync("triggerFileDownload", url, file.FileName, Auth.Token);
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Download failed: {ex.Message}");
        }
    }

    private async Task DeleteFile(FileEntryDto file)
    {
        var confirmed = await MessageBox.ConfirmAsync($"Delete '{file.FileName}'?");
        if (!confirmed)
        {
            return;
        }

        try
        {
            var fullPath = string.IsNullOrEmpty(Path) ? file.FileName : $"{Path}/{file.FileName}";
            await Api.DeleteFileAsync(DataSourceId, fullPath);
            await LoadAsync();
            Messenger.AddInformation("File deleted.");
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Failed to delete: {ex.Message}");
        }
    }

    private async Task DeleteFolder(FolderEntryDto folder)
    {
        var confirmed = await MessageBox.ConfirmAsync(
            $"Delete folder '{folder.Name}' and all {folder.FileCount} file(s) inside?");
        if (!confirmed)
        {
            return;
        }

        try
        {
            var folderPath = string.IsNullOrEmpty(Path)
                ? folder.Name + "/"
                : $"{Path}/{folder.Name}/";
            await Api.DeleteFolderAsync(DataSourceId, folderPath);
            await LoadAsync();
            Messenger.AddInformation("Folder deleted.");
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Failed to delete folder: {ex.Message}");
        }
    }

    private async Task DeleteAll()
    {
        if (_listing is null) return;
        var totalItems = _listing.Folders.Count + _listing.Files.Count;
        var confirmed = await MessageBox.ConfirmAsync(
            $"Delete ALL {totalItems} item(s) in this directory? This cannot be undone.");
        if (!confirmed) return;

        try
        {
            foreach (var folder in _listing.Folders)
            {
                var folderPath = string.IsNullOrEmpty(Path)
                    ? folder.Name + "/"
                    : $"{Path}/{folder.Name}/";
                await Api.DeleteFolderAsync(DataSourceId, folderPath);
            }
            foreach (var file in _listing.Files)
            {
                var fullPath = string.IsNullOrEmpty(Path) ? file.FileName : $"{Path}/{file.FileName}";
                await Api.DeleteFileAsync(DataSourceId, fullPath);
            }
            await LoadAsync();
            Messenger.AddInformation($"Deleted {totalItems} item(s).");
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Failed to delete all: {ex.Message}");
            await LoadAsync();
        }
    }

    private void ShowMoveFolder(FolderEntryDto folder)
    {
        _movingFolder = folder;
        _moveDestination = null;
    }

    private void CancelMove()
    {
        _movingFolder = null;
        _moveDestination = null;
    }

    private async Task ExecuteMove()
    {
        if (_movingFolder is null || string.IsNullOrEmpty(_moveDestination))
        {
            return;
        }

        try
        {
            var sourcePath = string.IsNullOrEmpty(Path)
                ? _movingFolder.Name + "/"
                : $"{Path}/{_movingFolder.Name}/";

            string destPath;
            if (_moveDestination == "..")
            {
                // Move to parent: strip one segment from Path
                var segments = GetPathSegments();
                var parentPath = segments.Count > 1
                    ? string.Join("/", segments.Take(segments.Count - 1))
                    : "";
                destPath = string.IsNullOrEmpty(parentPath)
                    ? _movingFolder.Name + "/"
                    : $"{parentPath}/{_movingFolder.Name}/";
            }
            else
            {
                // Move into sibling folder
                destPath = string.IsNullOrEmpty(Path)
                    ? $"{_moveDestination}/{_movingFolder.Name}/"
                    : $"{Path}/{_moveDestination}/{_movingFolder.Name}/";
            }

            await Api.MoveFolderAsync(DataSourceId, sourcePath, destPath);
            _movingFolder = null;
            _moveDestination = null;
            await LoadAsync();
            Messenger.AddInformation("Folder moved.");
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Failed to move folder: {ex.Message}");
        }
    }

    private static string FormatBytes(long bytes)
    {
        string[] sizes = ["B", "KB", "MB", "GB", "TB"];
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

}
