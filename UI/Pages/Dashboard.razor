@page "/"
@inject ApiService Api
@inject AuthService Auth
@inject NavigationManager Nav

@if (!Auth.IsAuthenticated)
{
    Nav.NavigateTo("/login");
    return;
}

<h3 class="mb-4"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h3>

@if (_dataSources is null)
{
    <div class="d-flex align-items-center">
        <div class="spinner-border spinner-border-sm me-2"></div>
        Loading...
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card text-bg-primary">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-database me-2"></i>Data Sources</h5>
                    <h2>@_dataSources.Count</h2>
                </div>
            </div>
        </div>

    </div>

    <div class="card mt-4">
        <div class="card-header">
            <i class="bi bi-info-circle me-2"></i>Quick Start
        </div>
        <div class="card-body">
            <ol>
                <li>Create a <strong>Data Source</strong> — configure a backend FTP/SFTP server, encryption method, and master password</li>
                <li>Enable frontends on the data source: <strong>HTTP</strong>, <strong>FTP</strong>, and/or <strong>SFTP</strong></li>
                <li>Upload files via the <a href="/datasources">web UI file explorer</a> or connect with an FTP/SFTP client</li>
                <li>Create an <a href="/tickets">Access Ticket</a> for FTP/SFTP/HTTP Basic auth (random username + password)</li>
                <li>
                    FTP: <code>ftp://@(_host):@(_config?.FtpPort ?? 2121)</code> &nbsp;|&nbsp;
                    FTPS: <code>ftps://@(_host):@(_config?.FtpPort ?? 2121)</code> <small class="text-muted">(explicit TLS, same port)</small> &nbsp;|&nbsp;
                    SFTP: <code>sftp://@(_host):@(_config?.SftpPort ?? 2222)</code>
                </li>
                <li>HTTP browse: <code>@(Nav.BaseUri)browse</code> (uses ticket credentials via Basic auth)</li>
                <li>Raw view: <code>@(Nav.BaseUri)raw</code> (view raw stored files without decryption)</li>
                <li>Files are encrypted at rest with your chosen algorithm (AES-CTR-256 default, AES-GCM-256, ChaCha20)</li>
                <li>Downloads are <strong>streamed and decrypted on-the-fly</strong> — no temp files on disk</li>
            </ol>
        </div>
    </div>
}

@code {
    private List<DataSourceDto>? _dataSources;
    private GlobalConfigModel? _config;
    private string _host = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated)
        {
            return;
        }

        _host = new Uri(Nav.BaseUri).Host;

        try
        {
            _dataSources = await Api.GetDataSourcesAsync();
            _config = await Api.GetGlobalConfigAsync();
        }
        catch
        {
            _dataSources = [];
        }
    }
}
