@page "/datasources"
@using Shared.Contracts
@using Shared.Models
@inject ApiService Api
@inject AuthService Auth
@inject NavigationManager Nav
@inject IHxMessengerService Messenger
@inject IHxMessageBoxService MessageBox
@inject IJSRuntime Js

@if (!Auth.IsAuthenticated)
{
    Nav.NavigateTo("/login");
    return;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3><i class="bi bi-database me-2"></i>Data Sources</h3>
    <HxButton Color="ThemeColor.Primary" OnClick="ShowCreateModal">
        <i class="bi bi-plus-lg me-1"></i> New Data Source
    </HxButton>
</div>

@if (_dataSources is null)
{
    <div class="d-flex align-items-center">
        <div class="spinner-border spinner-border-sm me-2"></div>
        Loading...
    </div>
}
else if (_dataSources.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>No data sources yet. Create one to start storing encrypted files.
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var ds in _dataSources)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="bi bi-folder-fill text-warning me-2"></i>@ds.Name
                        </h5>
                        <p class="card-text text-muted mb-1">
                            @ds.FileCount file(s) - @FormatBytes(ds.TotalFileSize)
                        </p>
                        <small class="text-muted d-block">@(ds.Backend.Protocol == BackendStorageType.SftpClient ? "SFTP" : "FTP"): @ds.Backend.Host:@ds.Backend.Port</small>
                        @foreach (var fe in ds.Frontends)
                        {
                            var badgeClass = fe.Type == FrontendType.Ftp ? "bg-info" : "bg-success";
                            <span class="badge @badgeClass me-1 mt-1">@fe.Type @(fe.AllowAnonymous ? "(anon)" : "")</span>
                        }
                        <span class="badge bg-secondary me-1 mt-1">@ds.Backend.EncryptionMethod</span>
                        <br />
                        <small class="text-muted">Created @ds.CreatedAt.LocalDateTime.ToString("MMM dd, yyyy")</small>
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <HxButton Color="ThemeColor.Primary" Size="ButtonSize.Small" OnClick="() => BrowseDataSource(ds.Id)">
                            <i class="bi bi-folder2-open me-1"></i> Browse
                        </HxButton>
                        <HxButton Color="ThemeColor.Secondary" Size="ButtonSize.Small" OnClick="() => ShowEditModal(ds)">
                            <i class="bi bi-pencil me-1"></i> Edit
                        </HxButton>
                        <HxButton Color="ThemeColor.Danger" Size="ButtonSize.Small" Outline="true" OnClick="() => DeleteDataSource(ds)">
                            <i class="bi bi-trash me-1"></i> Delete
                        </HxButton>
                    </div>
                </div>
            </div>
        }
    </div>
}

@* Create / Edit Modal *@
<HxModal @ref="_modal" Title="@(_editId.HasValue ? "Edit Data Source" : "New Data Source")">
    <BodyTemplate>
        <h6 class="text-muted mb-2">General</h6>
        <div class="mb-3">
            <HxInputText Label="Name" @bind-Value="_name" Placeholder="My Documents" />
        </div>
        <div class="mb-3">
            <label class="form-label">Encryption Method</label>
            @foreach (var method in Enum.GetValues<EncryptionMethod>())
            {
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="encryptionMethod"
                           id="enc-@method" value="@method" checked="@(_encryptionMethod == method)"
                           @onchange="() => _encryptionMethod = method" />
                    <label class="form-check-label" for="enc-@method">
                        @method
                        <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-html="true"
                           title="@GetEncryptionTooltip(method)"></i>
                    </label>
                </div>
            }
        </div>

        <h6 class="text-muted mb-2 mt-4">Backend Storage Server</h6>
        <div class="mb-3">
            <label class="form-label">Protocol</label>
            <div class="form-check">
                <input class="form-check-input" type="radio" name="backendProtocol"
                       id="proto-ftp" checked="@(_backendProtocol == BackendStorageType.FtpClient)"
                       @onchange="() => SetProtocol(BackendStorageType.FtpClient)" />
                <label class="form-check-label" for="proto-ftp">FTP</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="radio" name="backendProtocol"
                       id="proto-sftp" checked="@(_backendProtocol == BackendStorageType.SftpClient)"
                       @onchange="() => SetProtocol(BackendStorageType.SftpClient)" />
                <label class="form-check-label" for="proto-sftp">SFTP</label>
            </div>
        </div>
        <div class="row g-2 mb-3">
            <div class="col-8"><HxInputText Label="Host" @bind-Value="_backendHost" Placeholder="@(_backendProtocol == BackendStorageType.SftpClient ? "sftp.example.com" : "ftp.example.com")" /></div>
            <div class="col-4"><HxInputNumber Label="Port" @bind-Value="_backendPort" /></div>
        </div>
        <div class="row g-2 mb-3">
            <div class="col-6"><HxInputText Label="Username" @bind-Value="_backendUser" /></div>
            <div class="col-6"><HxInputText Label="Password" @bind-Value="_backendPass" Type="InputType.Password" /></div>
        </div>
        <div class="mb-3">
            <HxInputText Label="Base Path" @bind-Value="_backendPath" Placeholder="/" />
        </div>
        <div class="mb-3">
            <HxSwitch @bind-Value="_backendSsl" Text="Use SSL/TLS" />
        </div>
        <div class="mb-3">
            <HxInputText Label="Master Password" @bind-Value="_masterPassword" Type="InputType.Password"
                         Hint="Encryption key for files. Use the same password to re-attach to existing backends." />
        </div>

        <h6 class="text-muted mb-2 mt-4">Frontend Access</h6>
        <div class="mb-2">
            <HxSwitch @bind-Value="_ftpEnabled" Text="Enable FTP Server" />
            @if (_ftpEnabled)
            {
                <div class="ms-4 mt-1">
                    <HxSwitch @bind-Value="_ftpAnon" Text="Allow Anonymous" />
                </div>
            }
        </div>
        <div class="mb-2">
            <HxSwitch @bind-Value="_httpEnabled" Text="Enable HTTP File Server" />
            @if (_httpEnabled)
            {
                <div class="ms-4 mt-1">
                    <HxSwitch @bind-Value="_httpAnon" Text="Allow Anonymous" />
                </div>
            }
        </div>
        <div class="mb-2">
            <HxSwitch @bind-Value="_sftpEnabled" Text="Enable SFTP Server" />
            @if (_sftpEnabled)
            {
                <div class="ms-4 mt-1">
                    <HxSwitch @bind-Value="_sftpAnon" Text="Allow Anonymous" />
                </div>
            }
        </div>
        <small class="text-muted">Frontend access requires an access ticket. Generate one from your profile page.</small>
    </BodyTemplate>
    <FooterTemplate>
        <HxButton Color="ThemeColor.Secondary" OnClick="() => _modal.HideAsync()">Cancel</HxButton>
        <HxButton Color="ThemeColor.Primary" OnClick="SaveDataSource" Enabled="@IsFormValid()">
            @(_editId.HasValue ? "Save" : "Create")
        </HxButton>
    </FooterTemplate>
</HxModal>

@code {
    private List<DataSourceDto>? _dataSources;
    private HxModal _modal = null!;
    private Guid? _editId;

    // Form fields
    private string _name = string.Empty;
    private BackendStorageType _backendProtocol = BackendStorageType.FtpClient;
    private string _backendHost = string.Empty;
    private int _backendPort = 21;
    private string _backendUser = string.Empty;
    private string _backendPass = string.Empty;
    private string _backendPath = "/";
    private bool _backendSsl;
    private string _masterPassword = string.Empty;
    private bool _ftpEnabled;
    private bool _ftpAnon;
    private bool _httpEnabled;
    private bool _httpAnon;
    private bool _sftpEnabled;
    private bool _sftpAnon;
    private EncryptionMethod _encryptionMethod = EncryptionMethod.AesCtr256;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated) return;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _dataSources = await Api.GetDataSourcesAsync();
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Failed to load data sources: {ex.Message}");
            _dataSources = [];
        }
    }

    private async Task ShowCreateModal()
    {
        _editId = null;
        _name = string.Empty;
        _backendProtocol = BackendStorageType.FtpClient;
        _backendHost = string.Empty;
        _backendPort = 21;
        _backendUser = string.Empty;
        _backendPass = string.Empty;
        _backendPath = "/";
        _backendSsl = false;
        _masterPassword = string.Empty;
        _ftpEnabled = false;
        _ftpAnon = false;
        _httpEnabled = false;
        _httpAnon = false;
        _sftpEnabled = false;
        _sftpAnon = false;
        _encryptionMethod = EncryptionMethod.AesCtr256;
        await _modal.ShowAsync();
        await InitTooltipsAsync();
    }

    private async Task ShowEditModal(DataSourceDto ds)
    {
        _editId = ds.Id;
        _name = ds.Name;
        _backendProtocol = ds.Backend.Protocol;
        _backendHost = ds.Backend.Host;
        _backendPort = ds.Backend.Port;
        _backendUser = ds.Backend.Username;
        _backendPass = string.Empty; // Don't pre-fill password
        _backendPath = ds.Backend.BasePath;
        _backendSsl = ds.Backend.UseSsl;
        _masterPassword = string.Empty; // Don't pre-fill master password
        var ftpFrontend = ds.Frontends.FirstOrDefault(f => f.Type == FrontendType.Ftp);
        var httpFrontend = ds.Frontends.FirstOrDefault(f => f.Type == FrontendType.Http);
        var sftpFrontend = ds.Frontends.FirstOrDefault(f => f.Type == FrontendType.Sftp);
        _ftpEnabled = ftpFrontend is not null;
        _ftpAnon = ftpFrontend?.AllowAnonymous ?? false;
        _httpEnabled = httpFrontend is not null;
        _httpAnon = httpFrontend?.AllowAnonymous ?? false;
        _sftpEnabled = sftpFrontend is not null;
        _sftpAnon = sftpFrontend?.AllowAnonymous ?? false;
        _encryptionMethod = ds.Backend.EncryptionMethod;
        await _modal.ShowAsync();
        await InitTooltipsAsync();
    }

    private bool IsFormValid() =>
        !string.IsNullOrWhiteSpace(_name) && !string.IsNullOrWhiteSpace(_backendHost)
        && !string.IsNullOrWhiteSpace(_masterPassword);

    private void SetProtocol(BackendStorageType protocol)
    {
        // Auto-switch default port when toggling protocol
        if (_backendProtocol == BackendStorageType.FtpClient && _backendPort == 21)
            _backendPort = 22;
        else if (_backendProtocol == BackendStorageType.SftpClient && _backendPort == 22)
            _backendPort = 21;
        _backendProtocol = protocol;
    }

    private async Task SaveDataSource()
    {
        try
        {
            var backend = new BackendRequest(_backendProtocol, _backendHost, _backendPort, _backendUser, _backendPass, _backendPath, _backendSsl, _encryptionMethod, _masterPassword);
            var frontends = new List<FrontendRequest>();
            if (_ftpEnabled) frontends.Add(new FrontendRequest(FrontendType.Ftp, _ftpAnon));
            if (_httpEnabled) frontends.Add(new FrontendRequest(FrontendType.Http, _httpAnon));
            if (_sftpEnabled) frontends.Add(new FrontendRequest(FrontendType.Sftp, _sftpAnon));

            if (_editId.HasValue)
            {
                var req = new UpdateDataSourceRequest(_name.Trim(), backend, frontends);
                await Api.UpdateDataSourceAsync(_editId.Value, req);
                Messenger.AddInformation("Data source updated.");
            }
            else
            {
                var req = new CreateDataSourceRequest(_name.Trim(), backend, frontends);
                await Api.CreateDataSourceAsync(req);
                Messenger.AddInformation("Data source created.");
            }

            await _modal.HideAsync();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Failed to save: {ex.Message}");
        }
    }

    private async Task DeleteDataSource(DataSourceDto ds)
    {
        var confirmed = await MessageBox.ConfirmAsync($"Delete '{ds.Name}' and all its files?");
        if (!confirmed) return;

        try
        {
            await Api.DeleteDataSourceAsync(ds.Id);
            await LoadAsync();
            Messenger.AddInformation("Data source deleted.");
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Failed to delete: {ex.Message}");
        }
    }

    private static string FormatBytes(long bytes)
    {
        string[] sizes = ["B", "KB", "MB", "GB", "TB"];
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    private void BrowseDataSource(Guid id)
    {
        Nav.NavigateTo($"/files/{id}");
    }

    private async Task InitTooltipsAsync()
    {
        await Task.Yield();
        await Js.InvokeVoidAsync("eval",
            "document.querySelectorAll('[data-bs-toggle=tooltip]').forEach(el => bootstrap.Tooltip.getOrCreateInstance(el))");
    }

    private static string GetEncryptionTooltip(EncryptionMethod method) => method switch
    {
        EncryptionMethod.None =>
            "No encryption. Files stored as-is.\n" +
            "Pros: Fastest performance, no key management.\n" +
            "Cons: No confidentiality — anyone with backend access can read files.",
        EncryptionMethod.AesCtr256 =>
            "AES-256 in Counter mode. Stream cipher with random IV per file.\n" +
            "Pros: Fast, parallelizable, supports random access / streaming.\n" +
            "Cons: No built-in authentication — tampering is not detected.",
        EncryptionMethod.AesGcm256 =>
            "AES-256 in Galois/Counter mode. Authenticated encryption.\n" +
            "Pros: Confidentiality + integrity in one pass, hardware-accelerated (AES-NI).\n" +
            "Cons: 64 KB max per chunk for auth tag, slightly more overhead than CTR.",
        EncryptionMethod.ChaCha20Poly1305 =>
            "ChaCha20 stream cipher with Poly1305 MAC. Authenticated encryption.\n" +
            "Pros: Constant-time, no AES-NI needed, strong on ARM/mobile/older CPUs.\n" +
            "Cons: Slightly slower than AES-GCM on hardware with AES-NI.",
        _ => string.Empty
    };
}
