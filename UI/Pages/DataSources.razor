@page "/datasources"
@using Shared.Contracts
@using Shared.Models
@inject ApiService Api
@inject AuthService Auth
@inject NavigationManager Nav
@inject IHxMessengerService Messenger
@inject IHxMessageBoxService MessageBox

@if (!Auth.IsAuthenticated)
{
    Nav.NavigateTo("/login");
    return;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3><i class="bi bi-database me-2"></i>Data Sources</h3>
    <HxButton Color="ThemeColor.Primary" OnClick="ShowCreateModal">
        <i class="bi bi-plus-lg me-1"></i> New Data Source
    </HxButton>
</div>

@if (_dataSources is null)
{
    <div class="d-flex align-items-center">
        <div class="spinner-border spinner-border-sm me-2"></div>
        Loading...
    </div>
}
else if (_dataSources.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>No data sources yet. Create one to start storing encrypted files.
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var ds in _dataSources)
        {
            <div class="col-12">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="bi bi-folder-fill text-warning me-2"></i>@ds.Name
                        </h5>
                        <p class="card-text text-muted mb-1">
                            @ds.FileCount file(s) - @FormatBytes(ds.TotalFileSize)
                        </p>
                        <small class="text-muted d-block">@(ds.Backend.Protocol == BackendStorageType.SftpClient ? "SFTP" : "FTP"): @ds.Backend.Host:@ds.Backend.Port</small>
                        @foreach (var fe in ds.Frontends)
                        {
                            var badgeClass = fe.Type == FrontendType.Ftp ? "bg-info" : "bg-success";
                            <span class="badge @badgeClass me-1 mt-1">@fe.Type @(fe.AllowAnonymous ? "(anon)" : "")</span>
                        }
                        <span class="badge bg-secondary me-1 mt-1">@ds.Backend.EncryptionMethod</span>
                        @if (ds.Backend.EncryptionMethod != EncryptionMethod.None && _revealedPasswords.TryGetValue(ds.Id, out var pwd))
                        {
                            <div class="mt-1">
                                <small class="text-muted"><i class="bi bi-key me-1"></i>Master Password:</small>
                                <code class="ms-1 user-select-all text-warning">@pwd</code>
                                <button class="btn btn-sm btn-link p-0 ms-1" @onclick="() => _revealedPasswords.Remove(ds.Id)" title="Hide">
                                    <i class="bi bi-eye-slash"></i>
                                </button>
                            </div>
                        }
                        @if (ds.Frontends.Any(f => f.Type == FrontendType.Http))
                        {
                            <br />
                            <small class="text-muted">
                                <i class="bi bi-link-45deg me-1"></i>
                                <a href="@($"browse/{ds.Id}/")" target="_blank">@($"{Nav.BaseUri}browse/{ds.Id}/")</a>
                            </small>
                            @if (ds.Backend.EncryptionMethod != EncryptionMethod.None)
                            {
                            <br />
                            <small class="text-muted">
                                <i class="bi bi-file-binary me-1"></i>
                                <a href="@($"raw/{ds.Id}/")" target="_blank">@($"{Nav.BaseUri}raw/{ds.Id}/")</a> <span class="badge bg-danger" style="font-size:0.65em">RAW</span>
                            </small>
                            }
                        }
                        <br />
                        <small class="text-muted">Created @ds.CreatedAt.LocalDateTime.ToString("MMM dd, yyyy")</small>
                    </div>
                    <div class="card-footer">
                        @if (_progressMap.TryGetValue(ds.Id, out var prog))
                        {
                            <div class="d-flex align-items-center mb-2">
                                <div class="spinner-border spinner-border-sm text-info me-2" role="status"></div>
                                <span class="text-info small">@prog.Operation: @prog.Processed / @prog.TotalFiles file(s)…</span>
                            </div>
                        }
                        <div class="d-flex gap-2 flex-wrap align-items-center">
                        <HxButton Color="ThemeColor.Primary" Size="ButtonSize.Small" OnClick="() => BrowseDataSource(ds.Id)"
                                  Enabled="@(!_progressMap.ContainsKey(ds.Id))">
                            <i class="bi bi-folder2-open me-1"></i> Browse
                        </HxButton>
                        <HxButton Color="ThemeColor.Secondary" Size="ButtonSize.Small" OnClick="() => ShowEditModal(ds)"
                                  Enabled="@(!_progressMap.ContainsKey(ds.Id))">
                            <i class="bi bi-pencil me-1"></i> Edit
                        </HxButton>
                        @if (ds.Backend.EncryptionMethod != EncryptionMethod.None)
                        {
                            <HxButton Color="ThemeColor.Secondary" Size="ButtonSize.Small" Outline="true"
                                      OnClick="() => RevealMasterPassword(ds.Id)"
                                      Enabled="@(!_revealedPasswords.ContainsKey(ds.Id))">
                                <i class="bi bi-eye me-1"></i> Show Password
                            </HxButton>
                        }
                        <HxButton Color="ThemeColor.Info" Size="ButtonSize.Small" Outline="true"
                                  OnClick="() => DecryptDataSource(ds)" title="Decrypt all files"
                                  Enabled="@(ds.Backend.EncryptionMethod != EncryptionMethod.None && !_progressMap.ContainsKey(ds.Id))">
                            <i class="bi bi-unlock me-1"></i> Decrypt All
                        </HxButton>
                        <HxButton Color="ThemeColor.Warning" Size="ButtonSize.Small" Outline="true"
                                  OnClick="() => ShowReEncryptDsModal(ds)" title="Re-encrypt all files"
                                  Enabled="@(!_progressMap.ContainsKey(ds.Id))">
                            <i class="bi bi-shield-lock me-1"></i> Re-encrypt All
                        </HxButton>
                        <HxButton Color="ThemeColor.Secondary" Size="ButtonSize.Small" Outline="true"
                                  OnClick="() => DuplicateDataSource(ds)">
                            <i class="bi bi-copy me-1"></i> Duplicate
                        </HxButton>
                        <HxButton Color="ThemeColor.Danger" Size="ButtonSize.Small" Outline="true" OnClick="() => DeleteDataSource(ds)"
                                  Enabled="@(!_progressMap.ContainsKey(ds.Id))">
                            <i class="bi bi-trash me-1"></i> Delete
                        </HxButton>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@* Create / Edit Modal *@
<HxModal @ref="_modal" Title="@(_editId.HasValue ? "Edit Data Source" : "New Data Source")" Size="ModalSize.Large">
    <BodyTemplate>
        <h6 class="text-muted mb-2">General</h6>
        <div class="mb-3">
            <HxInputText Label="Name" @bind-Value="_name" Placeholder="My Documents" />
        </div>
        <div class="mb-3">
            <label class="form-label">Encryption Method</label>
            @if (_editId.HasValue)
            {
                <div class="text-muted small"><i class="bi bi-lock me-1"></i>@_encryptionMethod — use Re-encrypt to change.</div>
            }
            else
            {
            @foreach (var method in Enum.GetValues<EncryptionMethod>())
            {
                <div class="form-check mb-2">
                    <input class="form-check-input" type="radio" name="encryptionMethod"
                           id="enc-@method" value="@method" checked="@(_encryptionMethod == method)"
                           @onchange="() => _encryptionMethod = method" />
                    <label class="form-check-label" for="enc-@method">
                        <strong>@method</strong>
                        <div class="text-muted small">@GetEncryptionDescription(method)</div>
                    </label>
                </div>
            }
            }
        </div>

        <h6 class="text-muted mb-2 mt-4">Backend Storage Server</h6>
        <div class="mb-3">
            <label class="form-label">Protocol</label>
            <div class="form-check">
                <input class="form-check-input" type="radio" name="backendProtocol"
                       id="proto-ftp" checked="@(_backendProtocol == BackendStorageType.FtpClient)"
                       @onchange="() => SetProtocol(BackendStorageType.FtpClient)" />
                <label class="form-check-label" for="proto-ftp">FTP</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="radio" name="backendProtocol"
                       id="proto-sftp" checked="@(_backendProtocol == BackendStorageType.SftpClient)"
                       @onchange="() => SetProtocol(BackendStorageType.SftpClient)" />
                <label class="form-check-label" for="proto-sftp">SFTP</label>
            </div>
        </div>
        <div class="row g-2 mb-3">
            <div class="col-8"><HxInputText Label="Host" @bind-Value="_backendHost" Placeholder="@(_backendProtocol == BackendStorageType.SftpClient ? "sftp.example.com" : "ftp.example.com")" /></div>
            <div class="col-4"><HxInputNumber Label="Port" @bind-Value="_backendPort" /></div>
        </div>
        <div class="row g-2 mb-3">
            <div class="col-6"><HxInputText Label="Username" @bind-Value="_backendUser" /></div>
            <div class="col-6"><HxInputText Label="Password" @bind-Value="_backendPass" Type="InputType.Password"
                                             Placeholder="@(_editId.HasValue ? "(unchanged)" : "")" /></div>
        </div>
        <div class="mb-3">
            <HxInputText Label="Base Path" @bind-Value="_backendPath" Placeholder="backup"
                         Hint="Relative path on the remote server (no leading slash). e.g. backup, data/files" />
            @if (_backendPath.StartsWith('/'))
            {
                <div class="text-warning small mt-1"><i class="bi bi-exclamation-triangle me-1"></i>Leading slash will be removed. Use a relative path.</div>
            }
        </div>
        @if (_backendProtocol == BackendStorageType.FtpClient)
        {
            <div class="mb-3">
                <HxSwitch @bind-Value="_backendSsl" Text="Use SSL/TLS (FTPS)" />
                <small class="text-muted">Upgrades the FTP connection to use TLS encryption.</small>
            </div>
        }
        @if (_encryptionMethod != EncryptionMethod.None && !_editId.HasValue)
        {
            <div class="mb-3">
                <HxInputText Label="Master Password" @bind-Value="_masterPassword" Type="InputType.Password"
                             Placeholder=""
                             Hint="Encryption key for files. Use the same password to re-attach to existing backends." />
            </div>
        }
        @if (_encryptionMethod != EncryptionMethod.None && _editId.HasValue)
        {
            <div class="mb-3 text-muted small"><i class="bi bi-lock me-1"></i>Master password cannot be changed after creation.</div>
        }

        <h6 class="text-muted mb-2 mt-4">Frontend Access</h6>
        <div class="mb-2">
            <HxSwitch @bind-Value="_ftpEnabled" Text="Enable FTP Server" />
            @if (_ftpEnabled)
            {
                <div class="ms-4 mt-1">
                    <HxSwitch @bind-Value="_ftpAnon" Text="Allow Anonymous" />
                </div>
            }
        </div>
        <div class="mb-2">
            <HxSwitch @bind-Value="_httpEnabled" Text="Enable HTTP File Server" />
            @if (_httpEnabled)
            {
                <div class="ms-4 mt-1">
                    <HxSwitch @bind-Value="_httpAnon" Text="Allow Anonymous" />
                </div>
            }
        </div>
        <div class="mb-2">
            <HxSwitch @bind-Value="_sftpEnabled" Text="Enable SFTP Server" />
            @if (_sftpEnabled)
            {
                <div class="ms-4 mt-1">
                    <HxSwitch @bind-Value="_sftpAnon" Text="Allow Anonymous" />
                </div>
            }
        </div>
        <small class="text-muted">Frontend access requires an access ticket. Generate one from your profile page.</small>
    </BodyTemplate>
    <FooterTemplate>
        <HxButton Color="ThemeColor.Secondary" OnClick="() => _modal.HideAsync()">Cancel</HxButton>
        <HxButton Color="ThemeColor.Primary" OnClick="SaveDataSource" Enabled="@IsFormValid()">
            @(_editId.HasValue ? "Save" : "Create")
        </HxButton>
    </FooterTemplate>
</HxModal>

<HxModal @ref="_reEncryptDsModal" Title="Re-encrypt Data Source">
    <BodyTemplate>
        @if (_reEncryptingDs is not null)
        {
            <p>Re-encrypt all files in <strong>@_reEncryptingDs.Name</strong> (<strong>@_reEncryptingDs.FileCount</strong> file(s)).</p>
            <p class="text-muted small">Each file is streamed through decrypt → re-encrypt without loading it fully into memory.</p>
            <div class="mb-3">
                <label class="form-label">Target Encryption</label>
                <select class="form-select" @bind="_dsReEncryptMethod">
                    <option value="@EncryptionMethod.None">None (plaintext)</option>
                    <option value="@EncryptionMethod.AesCtr256">AES-CTR-256</option>
                    <option value="@EncryptionMethod.AesGcm256">AES-GCM-256</option>
                    <option value="@EncryptionMethod.ChaCha20Poly1305">ChaCha20-Poly1305</option>
                </select>
            </div>
        }
    </BodyTemplate>
    <FooterTemplate>
        <HxButton Color="ThemeColor.Secondary" OnClick="() => _reEncryptDsModal.HideAsync()">Cancel</HxButton>
        <HxButton Color="ThemeColor.Warning" OnClick="ReEncryptDataSource">Re-encrypt All</HxButton>
    </FooterTemplate>
</HxModal>

@code {
    private List<DataSourceDto>? _dataSources;
    private HxModal _modal = null!;
    private HxModal _reEncryptDsModal = null!;
    private DataSourceDto? _reEncryptingDs;
    private EncryptionMethod _dsReEncryptMethod = EncryptionMethod.AesCtr256;
    private Guid? _editId;
    private readonly Dictionary<Guid, BulkOperationProgress> _progressMap = [];
    private readonly Dictionary<Guid, string> _revealedPasswords = [];
    private CancellationTokenSource? _pollCts;

    // Form fields
    private string _name = string.Empty;
    private BackendStorageType _backendProtocol = BackendStorageType.FtpClient;
    private string _backendHost = string.Empty;
    private int _backendPort = 21;
    private string _backendUser = string.Empty;
    private string _backendPass = string.Empty;
    private string _backendPath = string.Empty;
    private bool _backendSsl;
    private string _masterPassword = string.Empty;
    private bool _ftpEnabled;
    private bool _ftpAnon;
    private bool _httpEnabled;
    private bool _httpAnon;
    private bool _sftpEnabled;
    private bool _sftpAnon;
    private EncryptionMethod _encryptionMethod = EncryptionMethod.AesCtr256;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated)
        {
            return;
        }

        await LoadAsync();
        await CheckRunningOpsAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _dataSources = await Api.GetDataSourcesAsync();
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Failed to load data sources: {ex.Message}");
            _dataSources = [];
        }
    }

    private async Task CheckRunningOpsAsync()
    {
        if (_dataSources is null) return;

        foreach (var ds in _dataSources)
        {
            try
            {
                var progress = await Api.GetDataSourceProgressAsync(ds.Id);
                if (progress is not null)
                {
                    _progressMap[ds.Id] = progress;
                    StartPolling(ds.Id);
                }
            }
            catch { /* ignore */ }
        }
    }

    private void StartPolling(Guid dsId)
    {
        _pollCts ??= new CancellationTokenSource();
        var ct = _pollCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                while (!ct.IsCancellationRequested)
                {
                    await Task.Delay(1500, ct);
                    try
                    {
                        var progress = await Api.GetDataSourceProgressAsync(dsId);
                        if (progress is null)
                        {
                            _progressMap.Remove(dsId);
                            await InvokeAsync(async () =>
                            {
                                await LoadAsync();
                                StateHasChanged();
                            });
                            break;
                        }
                        _progressMap[dsId] = progress;
                        await InvokeAsync(StateHasChanged);
                    }
                    catch { break; }
                }
            }
            catch (OperationCanceledException) { }
        });
    }

    private async Task ShowCreateModal()
    {
        _editId = null;
        _name = string.Empty;
        _backendProtocol = BackendStorageType.FtpClient;
        _backendHost = string.Empty;
        _backendPort = 21;
        _backendUser = string.Empty;
        _backendPass = string.Empty;
        _backendPath = string.Empty;
        _backendSsl = false;
        _masterPassword = string.Empty;
        _ftpEnabled = true;
        _ftpAnon = false;
        _httpEnabled = true;
        _httpAnon = false;
        _sftpEnabled = true;
        _sftpAnon = false;
        _encryptionMethod = EncryptionMethod.AesCtr256;
        await _modal.ShowAsync();
    }

    private async Task DuplicateDataSource(DataSourceDto ds)
    {
        DataSourceCredentialsResponse? creds = null;
        try
        {
            creds = await Api.GetCredentialsAsync(ds.Id);
        }
        catch
        {
            Messenger.AddError("Failed to fetch credentials for duplication.");
            return;
        }

        _editId = null;
        _name = $"Copy of {ds.Name}";
        _backendProtocol = ds.Backend.Protocol;
        _backendHost = ds.Backend.Host;
        _backendPort = ds.Backend.Port;
        _backendUser = ds.Backend.Username;
        _backendPass = creds?.BackendPassword ?? string.Empty;
        _backendPath = ds.Backend.BasePath;
        _backendSsl = ds.Backend.UseSsl;
        _encryptionMethod = ds.Backend.EncryptionMethod;
        _masterPassword = creds?.MasterPassword ?? string.Empty;
        var ftpFrontend = ds.Frontends.FirstOrDefault(f => f.Type == FrontendType.Ftp);
        var httpFrontend = ds.Frontends.FirstOrDefault(f => f.Type == FrontendType.Http);
        var sftpFrontend = ds.Frontends.FirstOrDefault(f => f.Type == FrontendType.Sftp);
        _ftpEnabled = ftpFrontend is not null;
        _ftpAnon = ftpFrontend?.AllowAnonymous ?? false;
        _httpEnabled = httpFrontend is not null;
        _httpAnon = httpFrontend?.AllowAnonymous ?? false;
        _sftpEnabled = sftpFrontend is not null;
        _sftpAnon = sftpFrontend?.AllowAnonymous ?? false;
        await _modal.ShowAsync();
    }

    private async Task ShowEditModal(DataSourceDto ds)
    {
        _editId = ds.Id;
        _name = ds.Name;
        _backendProtocol = ds.Backend.Protocol;
        _backendHost = ds.Backend.Host;
        _backendPort = ds.Backend.Port;
        _backendUser = ds.Backend.Username;
        _backendPass = string.Empty; // Don't pre-fill password
        _backendPath = ds.Backend.BasePath;
        _backendSsl = ds.Backend.UseSsl;
        _masterPassword = string.Empty; // Don't pre-fill master password
        var ftpFrontend = ds.Frontends.FirstOrDefault(f => f.Type == FrontendType.Ftp);
        var httpFrontend = ds.Frontends.FirstOrDefault(f => f.Type == FrontendType.Http);
        var sftpFrontend = ds.Frontends.FirstOrDefault(f => f.Type == FrontendType.Sftp);
        _ftpEnabled = ftpFrontend is not null;
        _ftpAnon = ftpFrontend?.AllowAnonymous ?? false;
        _httpEnabled = httpFrontend is not null;
        _httpAnon = httpFrontend?.AllowAnonymous ?? false;
        _sftpEnabled = sftpFrontend is not null;
        _sftpAnon = sftpFrontend?.AllowAnonymous ?? false;
        _encryptionMethod = ds.Backend.EncryptionMethod;
        await _modal.ShowAsync();
    }

    private bool IsFormValid() =>
        !string.IsNullOrWhiteSpace(_name) && !string.IsNullOrWhiteSpace(_backendHost)
        && (_encryptionMethod == EncryptionMethod.None || _editId.HasValue || !string.IsNullOrWhiteSpace(_masterPassword));

    private void SetProtocol(BackendStorageType protocol)
    {
        // Auto-switch default port when toggling protocol
        if (_backendProtocol == BackendStorageType.FtpClient && _backendPort == 21)
        {
            _backendPort = 22;
        }
        else if (_backendProtocol == BackendStorageType.SftpClient && _backendPort == 22)
        {
            _backendPort = 21;
        }

        _backendProtocol = protocol;
        // SSL/TLS only applies to FTP (FTPS); SFTP is always encrypted via SSH
        if (protocol == BackendStorageType.SftpClient)
        {
            _backendSsl = false;
        }
    }

    private async Task SaveDataSource()
    {
        try
        {
            var backend = new BackendRequest(_backendProtocol, _backendHost, _backendPort, _backendUser, _backendPass, _backendPath.TrimStart('/'), _backendSsl, _encryptionMethod, _masterPassword);
            var frontends = new List<FrontendRequest>();
            if (_ftpEnabled)
            {
                frontends.Add(new FrontendRequest(FrontendType.Ftp, _ftpAnon));
            }

            if (_httpEnabled)
            {
                frontends.Add(new FrontendRequest(FrontendType.Http, _httpAnon));
            }

            if (_sftpEnabled)
            {
                frontends.Add(new FrontendRequest(FrontendType.Sftp, _sftpAnon));
            }

            if (_editId.HasValue)
            {
                var req = new UpdateDataSourceRequest(_name.Trim(), backend, frontends);
                await Api.UpdateDataSourceAsync(_editId.Value, req);
                Messenger.AddInformation("Data source updated.");
            }
            else
            {
                var req = new CreateDataSourceRequest(_name.Trim(), backend, frontends);
                await Api.CreateDataSourceAsync(req);
                Messenger.AddInformation("Data source created.");
            }

            await _modal.HideAsync();
            await LoadAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Failed to save: {ex.Message}");
        }
    }

    private async Task DeleteDataSource(DataSourceDto ds)
    {
        var confirmed = await MessageBox.ConfirmAsync($"Delete '{ds.Name}' and all its files?");
        if (!confirmed)
        {
            return;
        }

        try
        {
            await Api.DeleteDataSourceAsync(ds.Id);
            await LoadAsync();
            Messenger.AddInformation("Data source deleted.");
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Failed to delete: {ex.Message}");
        }
    }

    private async Task RevealMasterPassword(Guid dsId)
    {
        try
        {
            var result = await Api.GetMasterPasswordAsync(dsId);
            _revealedPasswords[dsId] = result.Password;
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Failed to retrieve master password: {ex.Message}");
        }
    }

    private async Task DecryptDataSource(DataSourceDto ds)
    {
        var confirmed = await MessageBox.ConfirmAsync($"Decrypt all {ds.FileCount} file(s) in '{ds.Name}'? This removes encryption from every file.");
        if (!confirmed)
        {
            return;
        }

        _progressMap[ds.Id] = new BulkOperationProgress("Decrypt", ds.FileCount, 0);
        StateHasChanged();
        StartPolling(ds.Id);
        try
        {
            var result = await Api.DecryptDataSourceAsync(ds.Id);
            Messenger.AddInformation($"Decrypted {result.Processed}/{result.TotalFiles} file(s).");
        }
        catch (Refit.ApiException apiEx) when (apiEx.StatusCode == System.Net.HttpStatusCode.Conflict)
        {
            Messenger.AddWarning("A bulk operation is already running for this data source.");
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Bulk decrypt failed: {ex.Message}");
        }
        finally
        {
            _progressMap.Remove(ds.Id);
            await LoadAsync();
        }
    }

    private async Task ShowReEncryptDsModal(DataSourceDto ds)
    {
        _reEncryptingDs = ds;
        _dsReEncryptMethod = EncryptionMethod.AesCtr256;
        await _reEncryptDsModal.ShowAsync();
    }

    private async Task ReEncryptDataSource()
    {
        if (_reEncryptingDs is null)
        {
            return;
        }

        var dsId = _reEncryptingDs.Id;
        await _reEncryptDsModal.HideAsync();

        _progressMap[dsId] = new BulkOperationProgress("Re-encrypt", _reEncryptingDs.FileCount, 0);
        StateHasChanged();
        StartPolling(dsId);
        try
        {
            var result = await Api.ReEncryptDataSourceAsync(dsId, _dsReEncryptMethod);
            Messenger.AddInformation($"Re-encrypted {result.Processed}/{result.TotalFiles} file(s) to {_dsReEncryptMethod}.");
        }
        catch (Refit.ApiException apiEx) when (apiEx.StatusCode == System.Net.HttpStatusCode.Conflict)
        {
            Messenger.AddWarning("A bulk operation is already running for this data source.");
        }
        catch (Exception ex)
        {
            Messenger.AddError($"Bulk re-encrypt failed: {ex.Message}");
        }
        finally
        {
            _progressMap.Remove(dsId);
            await LoadAsync();
        }
    }

    private static string FormatBytes(long bytes)
    {
        string[] sizes = ["B", "KB", "MB", "GB", "TB"];
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    private void BrowseDataSource(Guid id)
    {
        Nav.NavigateTo($"/files/{id}");
    }

    private static string GetEncryptionDescription(EncryptionMethod method) => method switch
    {
        EncryptionMethod.None =>
            "No encryption. Fastest, but files are stored in plain text.",
        EncryptionMethod.AesCtr256 =>
            "AES-256 CTR — fast streaming cipher. No tamper detection.",
        EncryptionMethod.AesGcm256 =>
            "AES-256 GCM — authenticated encryption, hardware-accelerated (AES-NI).",
        EncryptionMethod.ChaCha20Poly1305 =>
            "ChaCha20-Poly1305 — authenticated encryption, fast without AES-NI.",
        _ => string.Empty
