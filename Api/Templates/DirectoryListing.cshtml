@model Api.ViewModels.DirectoryListingViewModel
@{
    var hasAnyRaw = Model.Entries.Any(e => e.RawHref != null);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <title>@Model.Title</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
    <style>
        :root { --bg: #1a1a2e; --bg-hover: #16213e; --text: #e0e0e0; --heading: @Model.AccentColor; --link: @Model.AccentColor; --muted: #888; --dim: #666; --border: #333; }
        [data-theme='light'] { --bg: #f5f5f5; --bg-hover: #e8e8e8; --text: #1a1a1a; --heading: @Model.AccentColorLight; --link: @Model.AccentColorLight; --muted: #666; --dim: #999; --border: #ddd; }
        body { font-family: 'JetBrains Mono', monospace; margin: 2em; background: var(--bg); color: var(--text); transition: background 0.2s, color 0.2s; }
        h1 { font-size: 1.4em; color: var(--heading); border-bottom: 1px solid var(--border); padding-bottom: 0.5em; }
        table { border-collapse: collapse; width: 100%; }
        th, td { text-align: left; padding: 4px 12px; }
        th { color: var(--muted); font-weight: normal; border-bottom: 1px solid var(--border); }
        tr:hover { background: var(--bg-hover); }
        a { color: var(--link); text-decoration: none; }
        a:hover { text-decoration: underline; }
        .size { color: var(--muted); text-align: right; }
        .date { color: var(--dim); }
        .header { display: flex; justify-content: space-between; align-items: center; }
        .theme-btn { background: none; border: 1px solid var(--border); color: var(--text); cursor: pointer; padding: 4px 10px; border-radius: 4px; font-family: inherit; font-size: 0.85em; }
        .theme-btn:hover { background: var(--bg-hover); }
        .raw { color: var(--muted); font-size: 0.85em; }
        .raw a { color: var(--muted); }
        .raw a:hover { color: var(--link); }
        .badge { background: var(--heading); color: #fff; padding: 2px 8px; border-radius: 4px; font-size: 0.75em; margin-left: 8px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>
            Index of @Model.CurrentPath
            @if (Model.Badge != null)
            {
                <span class="badge">@Model.Badge</span>
            }
        </h1>
        <button class="theme-btn" onclick="toggleTheme()" id="themeBtn">&#9728;&#65039; Light</button>
    </div>

    @if (Model.Subtitle != null)
    {
        <p style="color: var(--muted); font-size: 0.85em; margin-bottom: 1em;">@Model.Subtitle</p>
    }

    <table>
        <tr>
            <th>@Model.NameHeader</th>
            <th class="size">Size</th>
            <th class="date">@Model.DateHeader</th>
            @if (hasAnyRaw)
            {
                <th class="raw">Raw</th>
            }
        </tr>

        @if (Model.ParentHref != null)
        {
            <tr>
                <td><a href="@Model.ParentHref">../</a></td>
                <td class="size">-</td>
                <td class="date">-</td>
                @if (hasAnyRaw)
                {
                    <td class="raw"></td>
                }
            </tr>
        }

        @foreach (var entry in Model.Entries)
        {
            var isDir = entry.Href.EndsWith("/");
            var displayName = isDir ? entry.Name + "/" : entry.Name;
            var sizeStr = entry.Size.HasValue ? FormatSize(entry.Size.Value) : "-";
            var dateStr = entry.Modified.HasValue ? entry.Modified.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm") : "-";

            <tr>
                <td><a href="@entry.Href">@displayName</a></td>
                <td class="size">@sizeStr</td>
                <td class="date">@dateStr</td>
                @if (hasAnyRaw)
                {
                    <td class="raw">
                        @if (entry.RawHref != null)
                        {
                            <a href="@entry.RawHref" title="Download raw encrypted file">raw</a>
                        }
                    </td>
                }
            </tr>
        }
    </table>

    <script>
        function toggleTheme() {
            var html = document.documentElement;
            var current = html.getAttribute('data-theme');
            var next = current === 'light' ? 'dark' : 'light';
            html.setAttribute('data-theme', next);
            localStorage.setItem('browse-theme', next);
            updateBtn(next);
        }
        function updateBtn(t) {
            document.getElementById('themeBtn').textContent = t === 'light' ? '\u{1F319} Dark' : '\u{2600}\u{FE0F} Light';
        }
        (function () {
            var saved = localStorage.getItem('browse-theme') || 'dark';
            document.documentElement.setAttribute('data-theme', saved);
            updateBtn(saved);
        })();
    </script>
</body>
</html>

@functions {
    string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024 * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F1} GB";
    }
}
